{
  "manifest_version": 3,
  "name": "Money Data Collector",
  "version": "0.1.0",
  "description": "Collects financial data from supported institution websites",
  "permissions": ["activeTab", "storage", "cookies", "scripting", "webNavigation", "tabs"],
  "host_permissions": [
    "http://localhost:5555/*",
    "https://*.ally.com/*",
    "https://*.wealthfront.com/*",
    "https://*.betterment.com/*",
    "https://*.morganstanley.com/*",
    "https://*.solium.com/*",
    "https://*.capitalone.com/*",
    "https://*.bankofamerica.com/*",
    "https://*.chase.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.ally.com/*",
        "https://*.wealthfront.com/*",
        "https://*.betterment.com/*",
        "https://*.morganstanley.com/*",
        "https://*.solium.com/*",
        "https://*.capitalone.com/*",
        "https://*.bankofamerica.com/*",
        "https://*.chase.com/*"
      ],
      "js": ["content/network_recorder.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/page_interceptor.js"],
      "matches": [
        "https://*.ally.com/*",
        "https://*.wealthfront.com/*",
        "https://*.betterment.com/*",
        "https://*.morganstanley.com/*",
        "https://*.solium.com/*",
        "https://*.capitalone.com/*",
        "https://*.bankofamerica.com/*",
        "https://*.chase.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
