{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "index.html",
        "vite.config.ts",
        "vitest.config.ts",
        "package.json",
        "tsconfig*.json"
      ],
      "env": ["VITE_DOMAIN", "VITE_GOOGLE_MAPS_API_KEY"],
      "outputs": ["dist/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**",
        "index.html",
        "vite.config.ts",
        "package.json",
        "tsconfig*.json"
      ],
      "outputs": ["dist/types/**", "dist/.tsbuildinfo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "vite.config.ts",
        "vitest.config.ts",
        "vitest.e2e.config.ts",
        "package.json",
        "tsconfig*.json"
      ]
    },
    "test:playwright": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "PB_TEST_URL",
        "PB_URL",
        "TEST_PB_PORT",
        "TEST_API_PORT",
        "TEST_API_URL",
        "CI"
      ]
    }
  }
}
