{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": ["dist/types/**", "dist/.tsbuildinfo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:playwright": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "PB_TEST_URL",
        "PB_URL",
        "TEST_PB_PORT",
        "TEST_API_PORT",
        "TEST_API_URL",
        "CI"
      ]
    }
  }
}
