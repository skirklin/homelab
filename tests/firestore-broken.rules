// BROKEN RULES - for testing that tests catch the bugs
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if userId == request.auth.uid;
    }

    // Groceries - BROKEN: requires owner to read, can't add self to owners
    match /lists/{listId} {
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.owners);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.owners;
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.owners;

      match /items/{itemId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.owners;
      }

      match /history/{itemName} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.owners;
      }

      match /trips/{tripId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/lists/$(listId)).data.owners;
      }
    }

    // Upkeep - BROKEN: requires owner to read, can't add self to owners
    match /taskLists/{listId} {
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.owners);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.owners;
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.owners;

      match /tasks/{taskId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/taskLists/$(listId)).data.owners;
      }

      match /completions/{completionId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/taskLists/$(listId)).data.owners;
      }
    }
  }
}
