{
  "hosting": {
    "site": "groceries-kirkl",
    "public": "app/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "predeploy": ["npm --prefix app run build"]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "auth": {
      "port": 9199
    },
    "firestore": {
      "port": 8180
    },
    "ui": {
      "enabled": true,
      "port": 4100
    },
    "singleProjectMode": true
  }
}
