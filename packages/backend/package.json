    "test": "vitest run",
    "build": "tsc -b"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "date-fns-tz": "^3.2.0",
    "idb": "^8.0.3",
    "pocketbase": "^0.25.0"
