{
  "name": "@homelab/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./pocketbase": {
      "types": "./src/pocketbase/index.ts",
      "default": "./src/pocketbase/index.ts"
    },
    "./cache": {
      "types": "./src/cache/index.ts",
      "default": "./src/cache/index.ts"
    },
    "./wrapped-pb": {
      "types": "./src/wrapped-pb/index.ts",
      "default": "./src/wrapped-pb/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "pocketbase": "^0.25.0"
  }
}
