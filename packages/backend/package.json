{
  "name": "@homelab/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./pocketbase": {
      "types": "./src/pocketbase/index.ts",
      "default": "./src/pocketbase/index.ts"
    },
    "./wrapped-pb": {
      "types": "./src/wrapped-pb/index.ts",
      "default": "./src/wrapped-pb/index.ts"
    }
  },
  "scripts": {
