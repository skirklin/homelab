{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "rootDir": "src",
    "useDefineForClassFields": true,
    "types": ["vite/client"],
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["src/e2e"],
  "references": [
    { "path": "../../../packages/ui" }
  ]
}
