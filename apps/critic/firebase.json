{
  "hosting": [
    {
      "target": "editor",
      "public": "app/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "predeploy": [
        "npm --prefix app run build"
      ]
    },
    {
      "target": "critic",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*"
      ]
    }
  ]
}
