{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "noEmit": true,
    "useDefineForClassFields": true,
    "types": ["vite/client"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": false,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"],
  "exclude": ["src/e2e", "**/*.test.*"],
  "references": [
    { "path": "../../../packages/ui" },
    { "path": "../../shopping/app/tsconfig.app.json" },
    { "path": "../../recipes/app/tsconfig.app.json" },
    { "path": "../../life/app/tsconfig.app.json" },
    { "path": "../../upkeep/app/tsconfig.app.json" },
    { "path": "../../travel/app/tsconfig.app.json" }
  ]
}
