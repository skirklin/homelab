#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: reject commits containing likely secrets or personal data.

RED='\033[0;31m'
NC='\033[0m'

staged_files=$(git diff --cached --name-only --diff-filter=d)
if [ -z "$staged_files" ]; then
    exit 0
fi

failed=0

# Patterns: "label:::regex"
patterns=(
    "AWS access key:::AKIA[0-9A-Z]{16}"
    "AWS secret assignment:::(?i)aws_secret_access_key\s*[=:]\s*\S+"
    "Generic secret assignment:::(?i)(secret|token|api_key|apikey|auth_token|access_token|private_key)\s*[=:]\s*[\"'][^\s\"']{8,}"
    "1Password service account token:::ops_[A-Za-z0-9_\-]{20,}"
    "OP_SERVICE_ACCOUNT_TOKEN:::(?i)OP_SERVICE_ACCOUNT_TOKEN\s*[=:]\s*\S+"
    "GitHub token:::gh[pousr]_[A-Za-z0-9_]{36,}"
    "Bearer token:::(?i)bearer\s+[A-Za-z0-9\-._~+/]{20,}"
    "Private key:::-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----"
    "Slack token:::xox[bpoas]-[0-9a-zA-Z\-]{10,}"
    "Anthropic API key:::sk-ant-[A-Za-z0-9\-]{20,}"
    "OpenAI API key:::sk-[A-Za-z0-9]{20,}"
    "High-entropy hex secret:::(?i)(password|secret|token|key)\s*[=:]\s*[\"']?[0-9a-f]{32,}"
    "DB connection string with creds:::(?i)(mysql|postgres|mongodb|redis)://[^:]+:[^@]+@"
)

for entry in "${patterns[@]}"; do
    label="${entry%%:::*}"
    pattern="${entry##*:::}"

    for f in $staged_files; do
        # Don't scan the hook itself — it contains the detection patterns
        if [ "$f" = ".githooks/pre-commit" ]; then continue; fi
        if git show ":$f" 2>/dev/null | grep -qP "$pattern" 2>/dev/null; then
            echo -e "${RED}BLOCKED${NC}: $label in $f"
            git show ":$f" | grep -nP "$pattern" | head -3
            echo ""
            failed=1
        fi
    done
done

# Files that should never be committed
for f in $staged_files; do
    base=$(basename "$f")
    case "$base" in
        .env|*.pem|*.key|credentials.json|service-account.json|money.db)
            echo -e "${RED}BLOCKED${NC}: Forbidden file: $f"
            failed=1
            ;;
    esac
done

if [ "$failed" -ne 0 ]; then
    echo ""
    echo "Commit rejected due to potential secrets."
    echo "If this is a false positive, review carefully then use: git commit --no-verify"
    exit 1
fi
