{
  "manifest_version": 3,
  "name": "Recipe Clipper",
  "version": "0.1.0",
  "description": "Clip the recipe on the page you're viewing and save it to your homelab recipe boxes.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://api.kirkl.in/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
